{
  "name": "actly-editor",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "homepage": "https://fabianfreund.github.io/actly-editor",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:pages": "vite build --config vite.pages.config.ts",
    "preview:pages": "vite preview --config vite.pages.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:macos": "export PATH=\"$HOME/.cargo/bin:$PATH\" && npm run version:increment && npm run tauri:build",
    "version:bump": "npx tsx scripts/version.ts bump",
    "version:increment": "npx tsx scripts/version.ts increment",
    "version:show": "npx tsx scripts/version.ts show",
    "predeploy": "npm run build:pages",
    "deploy": "npx gh-pages -d dist-pages"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.4",
    "@uiw/react-codemirror": "^4.23.13",
    "@tanstack/react-query": "^5",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "@tauri-apps/plugin-store": "^2",
    "@types/uuid": "^10.0.0",
    "@xterm/addon-fit": "^0.10",
    "@xterm/xterm": "^5",
    "codemirror": "^6.0.1",
    "flexlayout-react": "^0.8",
    "lucide-react": "^0.469",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6"
  }
}
